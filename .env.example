# Copy to .env and fill in. Loaded by pydantic-settings (config.py) and docker-compose.
# .env is gitignored — never commit real keys.

# --- Mem0 Cloud (free tier: 10k adds / 1k searches per month, no Docker needed) ---
# Get your key at: https://app.mem0.ai -> API Keys
MEM0_API_KEY=m0-...
# Leave MEM0_HOST unset to use cloud. Set it to use self-hosted instead:
# MEM0_HOST=http://localhost:8888

# --- Gemini (used as victim LLM in profile_trust_experiment.py) ---
# Free tier at https://aistudio.google.com
GEMINI_API_KEY=AIza...

# --- OpenRouter (single key for Claude, GPT, Grok, Gemini — used by flip_hardened_multimodel.py) ---
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# --- Optional: direct provider keys (not needed if using OpenRouter) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Mem0 self-hosted only (docker compose up -d) ---
# MEM0_HOST=http://localhost:8888
# POSTGRES_PASSWORD=mem0
